{
    "version": 6,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "macos-arm64-debug",
            "inherits": "base",
            "displayName": "macOS ARM64 Debug (M4/M1+)",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -Werror",
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "CMAKE_PREFIX_PATH": "/opt/homebrew",
                "PAIRION_COVERAGE": "ON"
            }
        },
        {
            "name": "macos-arm64-release",
            "inherits": "base",
            "displayName": "macOS ARM64 Release",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -Werror",
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "CMAKE_PREFIX_PATH": "/opt/homebrew"
            }
        },
        {
            "name": "macos-x86_64-debug",
            "inherits": "base",
            "displayName": "macOS x86_64 Debug (Intel)",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -Werror",
                "CMAKE_OSX_ARCHITECTURES": "x86_64",
                "CMAKE_PREFIX_PATH": "/usr/local",
                "PAIRION_COVERAGE": "ON"
            }
        },
        {
            "name": "macos-x86_64-release",
            "inherits": "base",
            "displayName": "macOS x86_64 Release",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -Werror",
                "CMAKE_OSX_ARCHITECTURES": "x86_64",
                "CMAKE_PREFIX_PATH": "/usr/local"
            }
        },
        {
            "name": "linux-x86_64-debug",
            "inherits": "base",
            "displayName": "Linux x86_64 Debug",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -Werror",
                "PAIRION_COVERAGE": "ON"
            }
        },
        {
            "name": "linux-x86_64-release",
            "inherits": "base",
            "displayName": "Linux x86_64 Release",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -Werror"
            }
        },
        {
            "name": "linux-arm64-debug",
            "inherits": "base",
            "displayName": "Linux ARM64 Debug (e.g. Pi)",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -Werror",
                "PAIRION_COVERAGE": "ON",
                "CMAKE_SYSTEM_PROCESSOR": "aarch64"
            }
        },
        {
            "name": "linux-arm64-release",
            "inherits": "base",
            "displayName": "Linux ARM64 Release",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -Werror",
                "CMAKE_SYSTEM_PROCESSOR": "aarch64"
            }
        },
        {
            "name": "windows-x86_64-debug",
            "inherits": "base",
            "displayName": "Windows x86_64 Debug",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS": "/W4 /WX",
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
            }
        },
        {
            "name": "windows-x86_64-release",
            "inherits": "base",
            "displayName": "Windows x86_64 Release",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_FLAGS": "/W4 /WX",
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
            }
        }
    ],
    "buildPresets": [
        { "name": "macos-arm64-debug", "configurePreset": "macos-arm64-debug" },
        { "name": "macos-arm64-release", "configurePreset": "macos-arm64-release" },
        { "name": "macos-x86_64-debug", "configurePreset": "macos-x86_64-debug" },
        { "name": "macos-x86_64-release", "configurePreset": "macos-x86_64-release" },
        { "name": "linux-x86_64-debug", "configurePreset": "linux-x86_64-debug" },
        { "name": "linux-x86_64-release", "configurePreset": "linux-x86_64-release" },
        { "name": "linux-arm64-debug", "configurePreset": "linux-arm64-debug" },
        { "name": "linux-arm64-release", "configurePreset": "linux-arm64-release" },
        { "name": "windows-x86_64-debug", "configurePreset": "windows-x86_64-debug" },
        { "name": "windows-x86_64-release", "configurePreset": "windows-x86_64-release" }
    ],
    "testPresets": [
        { "name": "macos-arm64-debug", "configurePreset": "macos-arm64-debug", "output": { "outputOnFailure": true } },
        { "name": "macos-x86_64-debug", "configurePreset": "macos-x86_64-debug", "output": { "outputOnFailure": true } },
        { "name": "linux-x86_64-debug", "configurePreset": "linux-x86_64-debug", "output": { "outputOnFailure": true } },
        { "name": "linux-arm64-debug", "configurePreset": "linux-arm64-debug", "output": { "outputOnFailure": true } },
        { "name": "windows-x86_64-debug", "configurePreset": "windows-x86_64-debug", "output": { "outputOnFailure": true } }
    ]
}